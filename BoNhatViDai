local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoHeal = false
local HEAL_THRESHOLD = 80

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.75,0,0.45,0) -- 💥 chỉnh xuống dưới Auto Farm
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,0,1,0)
button.Text = "Auto Heal OFF"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundColor3 = Color3.fromRGB(60,60,60)

-- bật/tắt
button.MouseButton1Click:Connect(function()
	AutoHeal = not AutoHeal
	button.Text = AutoHeal and "Auto Heal ON" or "Auto Heal OFF"
end)

-- AUTO HEAL
task.spawn(function()
	while task.wait(0.2) do
		if not AutoHeal then continue end

		local char = player.Character
		if not char then continue end

		local humanoid = char:FindFirstChild("Humanoid")
		if not humanoid then continue end

		if humanoid.Health < HEAL_THRESHOLD then
			
			local tool = char:FindFirstChild("băng gạc") 
				or player.Backpack:FindFirstChild("băng gạc")

			if tool then
				if tool.Parent ~= char then
					humanoid:EquipTool(tool)
				end

				tool:Activate()
			end
		end
	end
end)
