local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoHeal = true
local HEAL_THRESHOLD = 80

task.spawn(function()
	while task.wait(0.3) do
		if not AutoHeal then continue end

		local char = player.Character
		if not char then continue end

		local humanoid = char:FindFirstChild("Humanoid")
		if not humanoid then continue end

		if humanoid.Health < HEAL_THRESHOLD then
			
			-- 💥 lưu tool đang cầm
			local currentTool = char:FindFirstChildOfClass("Tool")

			-- tìm băng gạc
			local bandage = char:FindFirstChild("băng gạc") 
				or player.Backpack:FindFirstChild("băng gạc")

			if bandage then
				-- cầm băng gạc
				if bandage.Parent ~= char then
					humanoid:EquipTool(bandage)
				end

				-- dùng 1 lần
				bandage:Activate()

				-- chờ tí cho nó heal
				task.wait(0.3)

				-- 💥 đổi lại tool cũ
				if currentTool and currentTool.Parent ~= char then
					humanoid:EquipTool(currentTool)
				end
			end
		end
	end
end)
