local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoFarm = true -- bật sẵn

-- tìm NPC gần nhất (còn sống)
local function getNPC()
	local closest = nil
	local dist = math.huge

	for _,v in pairs(workspace:GetDescendants()) do
		if v.Name == "CityNPC"
		and v:FindFirstChild("HumanoidRootPart")
		and v:FindFirstChild("Humanoid")
		and v.Humanoid.Health > 0 then

			local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude

			if d < dist then
				dist = d
				closest = v
			end
		end
	end

	return closest
end

-- AUTO FARM (không bị đứng nữa)
task.spawn(function()
	while task.wait(0.01) do
		if AutoFarm and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then

			local npc = getNPC()

			if npc and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
				local hrp = player.Character.HumanoidRootPart

				-- TELE LIÊN TỤC
				hrp.CFrame = npc.HumanoidRootPart.CFrame * CFrame.new(0, 3, 3)

				-- đánh liên tục
				local tool = player.Character:FindFirstChildOfClass("Tool")
				if tool then
					tool:Activate()
				end
			end

		end
	end
end)
