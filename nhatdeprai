local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoRescue = false

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.75,0,0.45,0)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,0,1,0)
button.Text = "Auto Cứu OFF"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundColor3 = Color3.fromRGB(60,60,60)

button.MouseButton1Click:Connect(function()
AutoRescue = not AutoRescue
button.Text = AutoRescue and "Auto Cứu ON" or "Auto Cứu OFF"
end)

local function findPrompt()
for _,v in pairs(workspace:GetDescendants()) do
if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
return v
end
end
end

task.spawn(function()
while task.wait(0.2) do

if AutoRescue and player.Character then

local hrp = player.Character:FindFirstChild("HumanoidRootPart")
local prompt = findPrompt()

if hrp and prompt then

local part = prompt.Parent

-- teleport tới mục tiêu
hrp.CFrame = part.CFrame

-- tạo weld
local weld = Instance.new("WeldConstraint")
weld.Part0 = hrp
weld.Part1 = part
weld.Parent = hrp

prompt.MaxActivationDistance = 100

pcall(function()
fireproximityprompt(prompt)
end)

task.wait(0.3)

weld:Destroy()

end
end

end
end)
