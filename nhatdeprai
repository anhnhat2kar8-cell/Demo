-- NoClip
task.spawn(function()
	while true do
		task.wait()
		if player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			if hrp and AutoRescue then
				hrp.AssemblyLinearVelocity = Vector3.zero
				hrp.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end
end)

-- tìm prompt ưu tiên Lụm
local function findPrompt()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Lụm" then
			local obj = v.Parent
			if obj and obj:IsA("BasePart") then
				return v, obj
			end
		end
	end

	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
			local char = v:FindFirstAncestorOfClass("Model")
			if char and char:FindFirstChild("HumanoidRootPart") then
				return v, char.HumanoidRootPart
			end
		end
	end
end

-- auto cứu + lụm
