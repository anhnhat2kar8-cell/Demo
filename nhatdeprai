local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
local AutoFarm = false

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,70)
frame.Position = UDim2.new(0.75,0,0.3,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,-20,1,-20)
button.Position = UDim2.new(0,10,0,10)
button.Text = "Auto Farm OFF"
button.BackgroundColor3 = Color3.fromRGB(50,50,50)
button.TextColor3 = Color3.new(1,1,1)

button.MouseButton1Click:Connect(function()
	AutoFarm = not AutoFarm
	button.Text = "Auto Farm "..(AutoFarm and "ON" or "OFF")
end)

-- tìm part của NPC
local function getNPCPart()

	local folder = workspace:FindFirstChild("NPCs")
	if not folder then return end

	for _,npc in pairs(folder:GetChildren()) do
		if npc.Name == "CityNPC" then

			for _,part in pairs(npc:GetChildren()) do
				if part:IsA("BasePart") then
					return part
				end
			end

		end
	end

end

-- auto farm
task.spawn(function()
	while task.wait(0.15) do
		if AutoFarm then

			local npcPart = getNPCPart()
			local char = player.Character

			if npcPart and char and char:FindFirstChild("HumanoidRootPart") then

				char.HumanoidRootPart.CFrame =
					npcPart.CFrame * CFrame.new(0,0,2)

				if char:FindFirstChildOfClass("Tool") then
					VirtualUser:ClickButton1(Vector2.new())
				end

			end

		end
	end
end)
