knobCorner.CornerRadius = UDim.new(1,0)

-- bật tắt
knob.MouseButton1Click:Connect(function()
	AutoRescue = not AutoRescue

	if AutoRescue then
		knob:TweenPosition(UDim2.new(0.52,0,0,1),"Out","Quad",0.2,true)

		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			SavedPos = player.Character.HumanoidRootPart.CFrame
		end
	else
		knob:TweenPosition(UDim2.new(0,1,0,1),"Out","Quad",0.2,true)

		if SavedPos and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			player.Character.HumanoidRootPart.CFrame = SavedPos
		end
	end
end)

-- NoClip
task.spawn(function()
	while true do
		task.wait()
		if AutoRescue and player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				hrp.AssemblyLinearVelocity = Vector3.zero
				hrp.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end
end)

-- tìm tiền
local function findLoot()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Lụm" then
			local obj = v.Parent
			if obj and obj:IsA("BasePart") then
				return v, obj
			end
		end
	end
end

-- lấy tất cả target cứu
local function getAllRescueTargets()
	local targets = {}

	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
			local char = v:FindFirstAncestorOfClass("Model")
			if char and char:FindFirstChild("HumanoidRootPart") then
				table.insert(targets,{
					prompt = v,
					hrp = char.HumanoidRootPart
				})
			end
		end
	end

	return targets
end

-- auto cứu + lụm
task.spawn(function()
	while task.wait(0.05) do
		if AutoRescue and player.Character then
			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			-- ưu tiên tiền trước
			local lootPrompt, lootTarget = findLoot()
			if lootPrompt and lootTarget then
				lootPrompt.MaxActivationDistance = 50
				lootPrompt.HoldDuration = 0

				hrp.CFrame = lootTarget.CFrame + Vector3.new(0, START_HEIGHT, 0)

				pcall(function()
					fireproximityprompt(lootPrompt)
				end)

				continue
			end

			-- cứu nhiều người liên tục
			for _,target in pairs(getAllRescueTargets()) do
				local prompt = target.prompt
				local targetHRP = target.hrp

				if prompt and targetHRP then
					prompt.MaxActivationDistance = 50
					prompt.HoldDuration = 0

					-- tele tới -14 trước
					hrp.CFrame = targetHRP.CFrame + Vector3.new(0, START_HEIGHT, 0)

					task.wait(0.08)

					-- bấm cứu trước
					pcall(function()
						fireproximityprompt(prompt)
					end)

					task.wait(0.05)

					-- rơi từ từ xuống -45
					for y = START_HEIGHT, TARGET_HEIGHT, -1 do
						hrp.CFrame = targetHRP.CFrame + Vector3.new(0, y, 0)
						task.wait(0.01)

						if hrp.Position.Y < SAFE_Y then
							hrp.CFrame = targetHRP.CFrame + Vector3.new(0, START_HEIGHT, 0)
							break
						end
					end

					task.wait(0.05)
				end
			end
		end
	end
end)
