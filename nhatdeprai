local Players = game:GetService("Players")
local player = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

local AutoRescue = false
local OldPos = nil
local UNDERGROUND = -12

-- Anti AFK
player.Idled:Connect(function()
	VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	task.wait(1)
	VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.75,0,0.45,0)
frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
frame.Active = true
frame.Draggable = true

-- bo góc
local frameCorner = Instance.new("UICorner", frame)
frameCorner.CornerRadius = UDim.new(0.10,0)

-- viền
local stroke = Instance.new("UIStroke", frame)
stroke.Thickness = 2
stroke.Color = Color3.fromRGB(255,0,0)

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,0,1,0)
button.Text = "Auto Cứu OFF"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundColor3 = Color3.fromRGB(20,20,20)

local buttonCorner = Instance.new("UICorner", button)
buttonCorner.CornerRadius = UDim.new(0.10,0)

button.MouseButton1Click:Connect(function()
	AutoRescue = not AutoRescue
	button.Text = AutoRescue and "Auto Cứu ON" or "Auto Cứu OFF"
end)

-- viền đổi màu nhẹ
task.spawn(function()
	local hue = 0
	while true do
		hue = hue + 0.002
		if hue > 1 then
			hue = 0
		end
		stroke.Color = Color3.fromHSV(hue,0.7,1)
		task.wait(0.02)
	end
end)

-- NoClip
task.spawn(function()
	while true do
		task.wait()
		if AutoRescue and player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end
end)

-- tìm prompt cứu
local function findPrompt()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
			local char = v:FindFirstAncestorOfClass("Model")
			if char and char:FindFirstChild("HumanoidRootPart") then
				return v, char.HumanoidRootPart
			end
		end
	end
end

task.spawn(function()
	while task.wait(0.25) do
		if AutoRescue and player.Character then

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			local prompt, targetHRP = findPrompt()

			if hrp and prompt and targetHRP then

				OldPos = hrp.CFrame
				prompt.MaxActivationDistance = 50

				hrp.CFrame = CFrame.new(
					targetHRP.Position.X,
					targetHRP.Position.Y + UNDERGROUND,
					targetHRP.Position.Z
				)

				task.wait(0.2)

				pcall(function()
					fireproximityprompt(prompt)
				end)

				task.wait(0.35)

				if OldPos then
					hrp.CFrame = OldPos
				end

			end
		end
	end
end)
