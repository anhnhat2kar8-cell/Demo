-- Services
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local LocalPlayer = Players.LocalPlayer

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0,200,0,80)
Frame.Position = UDim2.new(0.8,0,0.3,0)
Frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
Frame.Active = true
Frame.Draggable = true
Frame.Parent = ScreenGui
Instance.new("UICorner",Frame)

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0,180,0,40)
Button.Position = UDim2.new(0,10,0,20)
Button.Text = "⚔️ Auto Farm OFF"
Button.BackgroundColor3 = Color3.fromRGB(40,40,40)
Button.TextColor3 = Color3.fromRGB(255,255,255)
Button.Parent = Frame
Instance.new("UICorner",Button)

-- Toggle
local AutoFarm = false

Button.MouseButton1Click:Connect(function()
    AutoFarm = not AutoFarm
    Button.Text = "⚔️ Auto Farm "..(AutoFarm and "ON" or "OFF")
end)

-- Tìm NPC đi ngoài đường
local function getNPC()
    for _,v in pairs(workspace:GetDescendants()) do
        if v:FindFirstChild("Humanoid")
        and v:FindFirstChild("HumanoidRootPart")
        and not Players:GetPlayerFromCharacter(v) then

            if v.Humanoid.Health > 0 then
                return v
            end
        end
    end
end

-- Auto farm
task.spawn(function()
    while true do
        task.wait(0.2)

        if AutoFarm then
            local npc = getNPC()
            local char = LocalPlayer.Character

            if npc and char and char:FindFirstChild("HumanoidRootPart") then

                -- teleport tới NPC
                char.HumanoidRootPart.CFrame =
                    npc.HumanoidRootPart.CFrame * CFrame.new(0,0,3)

                -- đánh
                if char:FindFirstChildOfClass("Tool") then
                    VirtualUser:ClickButton1(Vector2.new())
                end
            end
        end
    end
end)
