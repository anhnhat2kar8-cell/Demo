local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoRescue = false
local OldPos = nil
local UNDERGROUND = -12

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,220,0,80)
frame.Position = UDim2.new(0.75,0,0.45,0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,30)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true

local corner = Instance.new("UICorner", frame)
corner.CornerRadius = UDim.new(0,12)

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(0,80,0,50)
button.Position = UDim2.new(0.05,0,0.5,-25)
button.BackgroundColor3 = Color3.fromRGB(50,50,60)
button.Text = "Enter"
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.TextColor3 = Color3.fromRGB(220,220,255)

local bcorner = Instance.new("UICorner", button)
bcorner.CornerRadius = UDim.new(0,10)

local label = Instance.new("TextLabel", frame)
label.Size = UDim2.new(0.5,0,1,0)
label.Position = UDim2.new(0.45,0,0,0)
label.BackgroundTransparency = 1
label.Text = "Auto Rescue"
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.TextColor3 = Color3.fromRGB(180,200,255)

local originalPos = button.Position

button.MouseButton1Click:Connect(function()

	AutoRescue = not AutoRescue

	if AutoRescue then
		-- hiệu ứng nút bị nhấn xuống
		button.Position = originalPos + UDim2.new(0,0,0,3)
		button.BackgroundColor3 = Color3.fromRGB(0,170,255)
	else
		-- nút nổi lại
		button.Position = originalPos
		button.BackgroundColor3 = Color3.fromRGB(50,50,60)
	end

end)

-- NoClip
task.spawn(function()
	while true do
		task.wait()
		if AutoRescue and player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end
end)

-- tìm prompt cứu
local function findPrompt()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
			local char = v:FindFirstAncestorOfClass("Model")
			if char and char:FindFirstChild("HumanoidRootPart") then
				return v, char.HumanoidRootPart
			end
		end
	end
end

task.spawn(function()
	while task.wait(0.25) do

		if AutoRescue and player.Character then

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			local prompt, targetHRP = findPrompt()

			if hrp and prompt and targetHRP then

				OldPos = hrp.CFrame

				-- tăng khoảng cách kích hoạt
				prompt.MaxActivationDistance = 50

				-- xuống lòng đất dưới player cần cứu
				hrp.CFrame = CFrame.new(
					targetHRP.Position.X,
					targetHRP.Position.Y + UNDERGROUND,
					targetHRP.Position.Z
				)

				task.wait(0.2)

				-- cứu từ dưới đất
				pcall(function()
					fireproximityprompt(prompt)
				end)

				task.wait(0.35)

				-- quay lại vị trí cũ
				if OldPos then
					hrp.CFrame = OldPos
				end

			end
		end

	end
end)
