local Players = game:GetService("Players")
local player = Players.LocalPlayer

local AutoFarm = false
local CurrentNPC = nil
local DIST = 9

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.75,0,0.35,0)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,0,1,0)
button.Text = "Auto Farm OFF"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundColor3 = Color3.fromRGB(60,60,60)

button.MouseButton1Click:Connect(function()
AutoFarm = not AutoFarm
button.Text = AutoFarm and "Auto Farm ON" or "Auto Farm OFF"
end)

-- tìm NPC
local function getNPC()
for _,v in pairs(workspace:GetDescendants()) do
if v.Name == "CityNPC"
and v:FindFirstChild("HumanoidRootPart")
and v:FindFirstChild("Humanoid")
and v.Humanoid.Health > 0 then
return v
end
end
end

-- AUTO LỤM
local function autoPickup()
for _,v in pairs(workspace:GetDescendants()) do
if v:IsA("ProximityPrompt") and v.ActionText == "Lụm" then
pcall(function()
fireproximityprompt(v)
end)
end
end
end

task.spawn(function()

while task.wait(0.12) do

if AutoFarm and player.Character then

local hrp = player.Character:FindFirstChild("HumanoidRootPart")

if not CurrentNPC
or not CurrentNPC.Parent
or CurrentNPC.Humanoid.Health <= 0 then
CurrentNPC = getNPC()
end

if CurrentNPC and hrp then

local npcHRP = CurrentNPC:FindFirstChild("HumanoidRootPart")

if npcHRP then

-- khóa chân NPC
local hum = CurrentNPC:FindFirstChild("Humanoid")
if hum then
hum.WalkSpeed = 0
hum.JumpPower = 0
end

-- tắt va chạm NPC
for _,p in pairs(CurrentNPC:GetDescendants()) do
if p:IsA("BasePart") then
p.CanCollide = false
end
end

-- giữ khoảng cách 9 stud
local targetPos = npcHRP.Position + (npcHRP.CFrame.LookVector * -DIST)
hrp.CFrame = CFrame.new(targetPos, npcHRP.Position)

-- đánh
local tool = player.Character:FindFirstChildOfClass("Tool")
if tool then
tool:Activate()
end

-- auto lụm
autoPickup()

end
end
end

end

end)
