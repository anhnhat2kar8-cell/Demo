button.MouseButton1Click:Connect(function()

	AutoRescue = not AutoRescue

	if AutoRescue then
		button.TextColor3 = Color3.fromRGB(0,255,200)
		glow.Color = Color3.fromRGB(0,255,200)
	else
		button.TextColor3 = Color3.fromRGB(150,150,150)
		glow.Color = Color3.fromRGB(80,80,80)
	end

end)

-- NoClip
task.spawn(function()
	while true do
		task.wait()
		if AutoRescue and player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end
end)

-- tìm prompt cứu
local function findPrompt()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") and v.ActionText == "Cứu" then
			local char = v:FindFirstAncestorOfClass("Model")
			if char and char:FindFirstChild("HumanoidRootPart") then
				return v, char.HumanoidRootPart
			end
		end
	end
end

task.spawn(function()
	while task.wait(0.25) do

		if AutoRescue and player.Character then

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			local prompt, targetHRP = findPrompt()

			if hrp and prompt and targetHRP then

				OldPos = hrp.CFrame

				-- tăng khoảng cách kích hoạt
				prompt.MaxActivationDistance = 50

				-- xuống lòng đất dưới player cần cứu
				hrp.CFrame = CFrame.new(
					targetHRP.Position.X,
					targetHRP.Position.Y + UNDERGROUND,
					targetHRP.Position.Z
				)

				task.wait(0.2)

				-- cứu từ dưới đất
				pcall(function()
					fireproximityprompt(prompt)
				end)

				task.wait(0.35)

				-- quay lại vị trí cũ
				if OldPos then
					hrp.CFrame = OldPos
				end

			end
		end

	end
end)
